{
  "uid": "hft-latency",
  "title": "HFT Latency",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["hft","latency"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "HTTP p50/p95/p99 per Service",
      "gridPos": {"x":0,"y":0,"w":24,"h":10},
      "targets": [
        {"expr":"histogram_quantile(0.50, sum by (le,service) (rate(http_server_requests_seconds_bucket[1m])))","legendFormat":"p50 {{service}}","refId":"A"},
        {"expr":"histogram_quantile(0.95, sum by (le,service) (rate(http_server_requests_seconds_bucket[1m])))","legendFormat":"p95 {{service}}","refId":"B"},
        {"expr":"histogram_quantile(0.99, sum by (le,service) (rate(http_server_requests_seconds_bucket[1m])))","legendFormat":"p99 {{service}}","refId":"C"}
      ],
      "datasource":{"type":"prometheus","uid":"prometheus"}
    },
    {
      "id": 2, "type": "timeseries", "title": "Order Processing Latency (per stage, p99)",
      "gridPos": {"x":0,"y":10,"w":12,"h":8},
      "targets": [
        {"expr":"histogram_quantile(0.99, sum by (le,stage) (rate(order_processing_latency_seconds_bucket[5m])))","legendFormat":"{{stage}}","refId":"A"}
      ],
      "datasource":{"type":"prometheus","uid":"prometheus"}
    },
    {
      "id": 3, "type": "timeseries", "title": "Matching Engine match latency (µs p99)",
      "gridPos": {"x":12,"y":10,"w":12,"h":8},
      "targets": [
        {"expr":"histogram_quantile(0.99, sum by (le) (rate(match_latency_microseconds_bucket[1m])))","legendFormat":"p99","refId":"A"}
      ],
      "datasource":{"type":"prometheus","uid":"prometheus"}
    },
    {
      "id": 4, "type": "timeseries", "title": "Risk Check Duration p99",
      "gridPos": {"x":0,"y":18,"w":24,"h":8},
      "targets": [
        {"expr":"histogram_quantile(0.99, sum by (le) (rate(risk_checks_duration_seconds_bucket[5m])))","legendFormat":"p99","refId":"A"}
      ],
      "datasource":{"type":"prometheus","uid":"prometheus"}
    }
  ]
}
