{
  "uid": "hft-risk",
  "title": "HFT Risk",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["hft","risk"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Rejections by Reason",
      "gridPos": {"x":0,"y":0,"w":24,"h":10},
      "targets": [{"expr":"sum by (reason) (rate(risk_rejections_total[1m]))","legendFormat":"{{reason}}","refId":"A"}],
      "datasource":{"type":"prometheus","uid":"prometheus"}
    },
    {
      "id": 2, "type": "stat", "title": "Approvals (1m rate)",
      "gridPos": {"x":0,"y":10,"w":8,"h":6},
      "targets": [{"expr":"sum(rate(risk_approvals_total[1m]))","refId":"A"}],
      "datasource":{"type":"prometheus","uid":"prometheus"}
    },
    {
      "id": 3, "type": "stat", "title": "Halted Users",
      "gridPos": {"x":8,"y":10,"w":8,"h":6},
      "targets": [{"expr":"sum(risk_halted_users_total)","refId":"A"}],
      "datasource":{"type":"prometheus","uid":"prometheus"}
    },
    {
      "id": 4, "type": "timeseries", "title": "Risk Check Duration p50/p95/p99",
      "gridPos": {"x":16,"y":10,"w":8,"h":6},
      "targets": [
        {"expr":"histogram_quantile(0.50, sum by (le) (rate(risk_checks_duration_seconds_bucket[5m])))","legendFormat":"p50","refId":"A"},
        {"expr":"histogram_quantile(0.95, sum by (le) (rate(risk_checks_duration_seconds_bucket[5m])))","legendFormat":"p95","refId":"B"},
        {"expr":"histogram_quantile(0.99, sum by (le) (rate(risk_checks_duration_seconds_bucket[5m])))","legendFormat":"p99","refId":"C"}
      ],
      "datasource":{"type":"prometheus","uid":"prometheus"}
    }
  ]
}
